PORT=5000

# MongoDB (required for persistence)
# Example (Atlas): mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string
# Optional (overrides db name in URI if provided)
MONGODB_DB_NAME=smart_finance_advisor

# JWT (required for real auth; if unset, backend runs in dev auth mode as user "1")
JWT_SECRET=your_long_random_secret

# Zerodha Kite API
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret

# Angel One SmartAPI
ANGELONE_API_KEY=your_angelone_smartapi_key
ANGELONE_CLIENT_ID=your_angelone_client_id
ANGELONE_PASSWORD=your_angelone_password
ANGELONE_TOTP=your_angelone_totp_secret

# AI Services
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here
GEMINI_API_KEY=your_gemini_api_key_here
